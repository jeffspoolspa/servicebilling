{
  "name": "internal-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --project-id vvprodiuwraceabviyes --schema public --schema billing > lib/db/types.ts",
    "db:diff": "supabase db diff",
    "wm:pull": "wmill sync pull --raw --filter 'f/billing/*' --filter 'f/shared/*' --filter 'f/webhooks/*'",
    "wm:push": "wmill sync push --raw --filter 'f/billing/*' --filter 'f/shared/*' --filter 'f/webhooks/*'",
    "script": "tsx",
    "set-password": "tsx scripts/set-password.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.460.0",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^16.2.2",
    "postcss": "^8.4.49",
    "supabase": "^1.215.0",
    "tailwindcss": "^3.4.14",
