# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://vvprodiuwraceabviyes.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from supabase dashboard>
SUPABASE_SERVICE_ROLE_KEY=<server only, never expose>

# Auth
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# In production: https://internal.jeffspoolspa.com

# Windmill (for scripts, CI, and API route triggers)
WINDMILL_TOKEN=<from 1password — Windmill > Settings > Tokens>
WINDMILL_BASE_URL=https://app.windmill.dev/api
WINDMILL_WORKSPACE=jps-internal
WMILL_TOKEN=<same as WINDMILL_TOKEN, used by CLI>

# QuickBooks Online webhook receiver (HMAC-SHA256 verifier token)
# Get this from: developer.intuit.com → My Apps → <app> → Webhooks → "Verifier Token"
# Webhook URL to paste into Intuit Developer Portal:
#   https://<your-vercel-domain>/api/webhooks/qbo
QBO_WEBHOOK_TOKEN=<from intuit developer portal>

# Shared API key the external website uses to POST leads to /api/leads.
# Generate a random secret; set the SAME value here and in the website's build env.
LEADS_INTAKE_API_KEY=<random secret; shared with the perfectpools-redesign site>

# Google Maps Places API key for the internal lead form's address autocomplete.
# Reuse the website's key or mint a domain-restricted one (must allow the app
# domain + localhost). If unset, the address field falls back to plain inputs.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<google maps places key>

# Mapbox token for the server-side address autocomplete proxy (/api/places/*).
# SERVER-ONLY (no NEXT_PUBLIC) — the token never reaches the browser. A public
# pk.* token works (geocoding is allowed); restrict its scopes/URLs in Mapbox.
# Trialing this to replace the Google Places autocomplete app-wide + on the site.
MAPBOX_TOKEN=<mapbox access token, pk.* is fine>

# Resend hosted-template UUID for the auto-sent lead quote (Resend dashboard →
# Templates → copy the template ID). Use {{{FIRST_NAME}}}, {{{MONTHLY_TOTAL}}},
# {{{MONTHLY_LOW}}}, {{{MONTHLY_HIGH}}}, {{{LABOR_MONTHLY}}}, {{{CHEM_ESTIMATE}}},
# {{{PER_VISIT}}}, {{{VISIT_FREQUENCY}}}, {{{OFFICE_NAME}}}, {{{OFFICE_PHONE}}}.
# If unset, lead-intake skips the email and falls back to an SMS quote.
RESEND_TEMPLATE_LEAD_QUOTE=<resend template uuid>

# Origin of the card-vault collect app (the iframe the in-app onboarding page
# embeds + the postMessage origin we trust). Defaults to the production vault.
NEXT_PUBLIC_CARD_VAULT_URL=https://secure.jeffspoolspa.com

# Customer-facing get-started/onboarding page (token appended as ?token=...).
# The quote auto-send embeds this link; same base the Windmill cadence uses.
GET_STARTED_URL=https://jeffspoolspa.github.io/perfectpools-redesign/get-started/
